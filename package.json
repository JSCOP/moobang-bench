{
  "name": "moobangbench",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "dev": "expo start --web",
    "check:data": "tsx scripts/check-data.ts",
    "build": "npm run check:data && expo export --platform web",
    "preview:cf": "wrangler pages dev dist",
    "db:migrate:local": "wrangler d1 execute moobangbench --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute moobangbench --remote --file=./schema.sql",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/ui": "~57.0.4",
    "expo": "~57.0.4",
    "expo-constants": "~57.0.3",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260711.1",
    "@types/react": "~19.2.2",
    "tsx": "^4.23.0",
    "typescript": "~6.0.3",
    "wrangler": "^4.110.0"
  }
}
